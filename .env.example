# AiliVili Backend Configuration
# Copy to .env and adjust for your environment

# Server
PORT=8080

# PostgreSQL (required)
DATABASE_URL=postgres://ailivili:ailivili@localhost:5432/ailivili?sslmode=disable

# JWT (required)
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_MINUTES=60

# Redis (optional — cache, rate limiting, pub/sub)
REDIS_URL=localhost:6379

# File Storage (STORAGE=local or minio)
STORAGE=local
STORAGE_BASE_URL=
# MinIO (only needed if STORAGE=minio)
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=ailivili
# MINIO_USE_SSL=false

# CORS
CORS_ORIGIN=*

# HLS
HLS_BASE_URL=http://localhost:8081

# Migrations
MIGRATIONS_DIR=migrations
